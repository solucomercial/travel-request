  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:local": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/server.js",
    "db:seed": "tsx src/scripts/seed.ts",
